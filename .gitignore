# Environment variables — never commit real secrets/config
.env
.env.local
.env.*.local

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Runtime application state — not source, must not be committed.
# alerts.db is a SQLite store for alert-subscription state, created/regenerated
# at runtime; it is machine/environment-specific and should never be pushed.
alerts.db
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pytype/

# Jupyter
.ipynb_checkpoints

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code / AI assistant workspace
.claude/

# Large/generated data artifacts — regenerate via scripts/fetch_states.py
# rather than committing; uncomment if you'd rather NOT track them.
# data/output/
# data/states/
# data/KERALA/
