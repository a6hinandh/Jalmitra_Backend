# Neo4j — local or Neo4j Aura (https://neo4j.com/cloud/aura/)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password

# --- Pinecone semantic search (OPTIONAL) ---
# The Pinecone + sentence-transformers vector-search layer is fully implemented
# but DISABLED by default. Enabling it loads torch + an embedding model into RAM
# (~400MB+), which OOM-kills a 512MB instance (e.g. Render free tier). Production
# therefore runs on Neo4j + Gemini only. Set PINECONE_ACTIVATION=true locally
# (where more RAM is available) to enable vector retrieval; when true, a valid
# PINECONE_API_KEY is required.
PINECONE_ACTIVATION=false
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=gw-index

# Google Gemini — https://aistudio.google.com/
GENAI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Embedding model — only used when PINECONE_ACTIVATION=true.
# all-MiniLM-L6-v2 (384-dim, ~90MB) is the lighter default; all-mpnet-base-v2
# (768-dim, ~420MB) is higher quality. The Pinecone index dimension must match.
EMBED_MODEL=all-MiniLM-L6-v2

# CORS — comma-separated list of allowed frontend origins
# Dev: http://localhost:3001,http://localhost:5173
# Prod: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

