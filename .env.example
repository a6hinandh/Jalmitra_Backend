# Neo4j — local or Neo4j Aura (https://neo4j.com/cloud/aura/)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password

# Pinecone — https://www.pinecone.io/
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=gw-index

# Google Gemini — https://aistudio.google.com/
GENAI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Embedding model (optional — defaults to all-mpnet-base-v2)
EMBED_MODEL=all-mpnet-base-v2

# CORS — comma-separated list of allowed frontend origins
# Dev: http://localhost:3001,http://localhost:5173
# Prod: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

